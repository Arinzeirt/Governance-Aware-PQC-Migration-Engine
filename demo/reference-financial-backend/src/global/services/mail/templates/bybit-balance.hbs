<html>
  <head>
    <meta http-equiv='Content-Type' content='text/html; charset=utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Bybit Balance Alert</title>
    <!--[if !mso]><!-->
    <style type='text/css'>
      @media only screen and (max-width: 600px) {
        .responsive-table {
          width: 100% !important;
        }
        .responsive-column {
          display: block !important;
          width: 100% !important;
        }
        .content-container {
          padding: 20px 15px !important;
        }
        .content-box {
          padding: 25px 20px !important;
        }
      }
    </style>
    <!--<![endif]-->
  </head>
  <body
    style='
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
      background-color: #f4f4f4;
    '
  >
    <table
      align='center'
      cellpadding='0'
      cellspacing='0'
      border='0'
      width='100%'
      style='max-width: 600px; background-color: #f4f4f4'
    >
      <!-- Header with Background Image -->
      <tr>
        <td
          style="
            background-image: url('https://streplestorage.s3.eu-north-1.amazonaws.com/images/Email+for+registerd+buyer.png');
            background-repeat: no-repeat;
            background-position: center top;
            padding: 150px 0 0 0;
            text-align: center;
          "
          background='https://streplestorage.s3.eu-north-1.amazonaws.com/images/Email+for+registerd+buyer.png'
        >
          <div class='content-container' style='padding: 0 20px'>
            <table
              align='center'
              cellpadding='0'
              cellspacing='0'
              border='0'
              width='100%'
              style='max-width: 500px'
            >
              <tr>
                <td>
                  <table
                    cellpadding='0'
                    cellspacing='0'
                    border='0'
                    width='100%'
                    style='
                      background-color: #ffffff;
                      border-radius: 12px;
                      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
                    '
                  >
                    <tr>
                      <td class='content-box' style='padding: 40px 30px'>
                        <h1
                          style='
                            text-align: center;
                            font-size: 28px;
                            color: #333;
                            margin: 0 0 25px 0;
                            font-weight: bold;
                          '
                        >
                          ⚠️
                          {{accountName}}
                          Balance Alert
                        </h1>

                        <p
                          style='
                            font-size: 16px;
                            line-height: 1.6;
                            color: #555;
                            margin: 0 0 15px 0;
                          '
                        >
                          Hello
                          <strong style='color: #333'>Admin</strong>,
                        </p>

                        <p
                          style='
                            font-size: 16px;
                            line-height: 1.6;
                            color: #555;
                            margin: 0 0 20px 0;
                          '
                        >
                          This is to inform you that the
                          {{accountName}}
                          account balance is currently
                          <strong style='color: #d9534f'>insufficient</strong>
                          to continue processing transactions.
                        </p>

                        <!-- Information Box -->
                        {{!-- <table
                          cellpadding='0'
                          cellspacing='0'
                          border='0'
                          width='100%'
                          style='
                            background-color: #f8f9fa;
                            border-radius: 8px;
                            margin: 20px 0;
                          '
                        >
                          <tr>
                            <td style='padding: 20px'>
                              <p
                                style='
                                  font-size: 16px;
                                  line-height: 1.6;
                                  color: #555;
                                  margin: 0 0 10px 0;
                                '
                              >
                                <strong style='color: #333'>Current Balance:</strong>
                                {{balance}}
                              </p>
                              <p
                                style='
                                  font-size: 16px;
                                  line-height: 1.6;
                                  color: #555;
                                  margin: 0;
                                '
                              >
                                <strong style='color: #333'>Minimum Required:</strong>
                                {{required_balance}}
                              </p>
                            </td>
                          </tr>
                        </table> --}}

                        <p
                          style='
                            font-size: 16px;
                            line-height: 1.6;
                            color: #555;
                            margin: 0 0 25px 0;
                          '
                        >
                          Please top up the
                          {{accountName}}
                          account as soon as possible to avoid interruptions in
                          automated operations.
                        </p>

                        <div style='text-align: center; margin: 30px 0'>
                          <a
                            href='{{dashboard_link}}'
                            style='
                              display: inline-block;
                              padding: 15px 30px;
                              background-color: #007bff;
                              color: #ffffff;
                              text-decoration: none;
                              border-radius: 8px;
                              font-size: 16px;
                              font-weight: bold;
                            '
                          >View Dashboard</a>
                        </div>

                        <p
                          style='
                            text-align: center;
                            font-style: italic;
                            font-size: 14px;
                            color: #777;
                            margin: 0;
                          '
                        >
                          If you need assistance, feel free to contact the
                          support team.
                        </p>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>
            </table>
          </div>
        </td>
      </tr>

      <!-- Social Media Section -->
      <tr>
        <td style='padding: 30px 20px 20px; text-align: center'>
          <table align='center' cellpadding='0' cellspacing='0' border='0'>
            <tr>
              <td style='padding: 0 10px'>
                <a
                  href='https://x.com/streplenetwork'
                  target='_blank'
                  style='display: block'
                >
                  <img
                    src='https://upload.wikimedia.org/wikipedia/commons/thumb/5/5a/X_icon_2.svg/240px-X_icon_2.svg.png'
                    width='28'
                    height='28'
                  />
                </a>
              </td>
              <td style='padding: 0 10px'>
                <a
                  href='https://www.instagram.com/streple.network'
                  target='_blank'
                  style='display: block'
                >
                  <img
                    src='https://cdn-icons-png.flaticon.com/512/2111/2111463.png'
                    width='28'
                    height='28'
                  />
                </a>
              </td>
              <td style='padding: 0 10px'>
                <a
                  href='https://www.linkedin.com/company/enet-innovation/'
                  target='_blank'
                  style='display: block'
                >
                  <img
                    src='https://cdn-icons-png.flaticon.com/512/3536/3536505.png'
                    width='28'
                    height='28'
                  />
                </a>
              </td>
              <td style='padding: 0 10px'>
                <a
                  href='https://t.me/StrepleCommunity'
                  target='_blank'
                  style='display: block'
                >
                  <img
                    src='https://cdn-icons-png.flaticon.com/512/2111/2111644.png'
                    width='28'
                    height='28'
                  />
                </a>
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- Footer -->
      <tr>
        <td
          style='
            padding: 20px 30px;
            text-align: center;
            font-size: 12px;
            color: #777;
            border-top: 1px solid #eeeeee;
            background-color: #ffffff;
          '
        >
          <div>
            <p style='margin: 0 0 5px 0; font-weight: bold'>Streple.com</p>
            <p style='margin: 0; line-height: 1.4'>
              491858 Peregrine Road, Hainault,<br />
              Ilford, Essex, United Kingdom
            </p>
          </div>
        </td>
      </tr>
    </table>
  </body>
</html>